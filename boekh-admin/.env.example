# --- bankingApp-admin back-end ---
HOST=0.0.0.0
PORT=8100
# Origins allowed to call this API (JSON list). Vite dev server by default.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Storage server (bankingApp-server) we read JSON from ---
STORAGE_BASE_URL=http://localhost:8000
# Shared API key that bankingApp-server requires. The client sends its
# SHA-256 hash as "Authorization: Bearer <hash>".
# Leave empty only if the server runs without a key.
STORAGE_API_KEY=
REQUEST_TIMEOUT=30

# --- Local mirror ---
# Files read from bankingApp-server are also written here, mirroring its
# storage/<person>/<name> layout. Existing files are overwritten.
LOCAL_STORAGE_DIR=./storage
