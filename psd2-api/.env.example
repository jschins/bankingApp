# Copy to .env and fill in. Do NOT commit .env or your private key.
#
# Create an application in the Enable Banking Control Panel (free for personal
# use): https://enablebanking.com/  ->  register  ->  Applications -> create.
# You get an Application ID and download a private RSA key (.pem).

# Application ID (used as the JWT "kid")
ENABLEBANKING_APP_ID=

# Path to the application's private key file (PEM). Keep this file out of git.
ENABLEBANKING_KEY_PATH=enablebanking_private_key.pem

# Bank selection. ING NL: country NL, ASPSP name "ING".
PSD2_COUNTRY=NL
PSD2_ASPSP=ING

# Redirect URL. Production apps require HTTPS (http://localhost is rejected).
# It only needs to be a page you can land on to read the ?code=... it carries.
# Must match exactly an Allowed redirect URL registered for your application.
PSD2_REDIRECT_URL=https://example.com/

# --- Used by the `consent` / `pull-consent` commands (dev fallback) ---
# In packaged executables these come from the bundled profile.json instead.
# Which person folder on bankingApp-server this consent belongs to (e.g. js, as).
PSD2_PERSON=
# bankingApp-server base URL and shared API passphrase.
# Leave blank if the server has none.
bankingApp_SERVER_URL=http://localhost:8000
bankingApp_SERVER_API_PASSPHRASE=
