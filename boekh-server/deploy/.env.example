# Copy to .env and fill in. Do NOT commit .env.

# --- App server ---
APP_MODULE=app.main:app
HOST=0.0.0.0
PORT=8000
# Number of uvicorn workers
WORKERS=1

# --- Storage ---
# Directory holding one JSON folder per person (e.g. js, as)
STORAGE_DIR=./storage

# --- Access control ---
# Shared raw passphrase required to read or write data. Leave empty to disable
# the check (local dev only). The SHA-256 hash of this passphrase must be sent
# by clients as "Authorization: Bearer <hash>".
# Example: "bankingAppouding dkg"
SERVER_API_PASSPHRASE=
# Optional direct hashed key. If set, it is used directly instead of
# hashing SERVER_API_PASSPHRASE.
API_KEY=
